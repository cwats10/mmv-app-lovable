name: Sync from Lovable

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout mmv-app repository
        uses: actions/checkout@v4
        with:
          repository: cwats10/mmv-app
          token: ${{ secrets.GITHUB_TOKEN }}
          path: mmv-app

      - name: Checkout mmv-app-lovable repository
        uses: actions/checkout@v4
        with:
          repository: cwats10/mmv-app-lovable
          token: ${{ secrets.GITHUB_TOKEN }}
          path: mmv-app-lovable

      - name: Sync source code and configuration
        run: |
          # Copy src directory
          if [ -d "mmv-app-lovable/src" ]; then
            rsync -av --delete mmv-app-lovable/src/ mmv-app/src/
          fi
          
          # Copy public directory
          if [ -d "mmv-app-lovable/public" ]; then
            rsync -av --delete mmv-app-lovable/public/ mmv-app/public/
          fi
          
          # Copy supabase directory
          if [ -d "mmv-app-lovable/supabase" ]; then
            rsync -av --delete mmv-app-lovable/supabase/ mmv-app/supabase/
          fi
          
          # Sync TypeScript and config files
          for file in tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts eslint.config.js postcss.config.js index.html; do
            if [ -f "mmv-app-lovable/$file" ]; then
              cp mmv-app-lovable/$file mmv-app/$file
            fi
          done

      - name: Create Pull Request
        uses: peter-evans/create-pull-request@v5
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          commit-message: 'sync: update from mmv-app-lovable'
          title: 'Sync: Update from mmv-app-lovable'
          body: 'Automated sync of changes from mmv-app-lovable'
          branch: sync/from-lovable
          delete-branch: true
